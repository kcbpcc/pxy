#!/bin/bash

# Install dependencies
sudo apt-get update
sudo apt-get install -y opam m4

# Initialize opam
opam init --disable-sandboxing

# Install opam dependencies
opam install -y depext
opam depext -y google-drive-ocamlfuse
opam install -y google-drive-ocamlfuse

# Authenticate Google Drive
google-drive-ocamlfuse

# Create a mount point
mkdir ~/gdrive

# Mount Google Drive
google-drive-ocamlfuse ~/gdrive

echo "Google Drive has been mounted at ~/gdrive."

# Optional: Add an entry to /etc/fstab for automatic mounting on boot
echo "google-drive-ocamlfuse#$(realpath ~/gdrive) $(realpath ~/gdrive) fuse user,auto 0 0" | sudo tee -a /etc/fstab

echo "Setup complete. You can access your Google Drive at ~/gdrive."
