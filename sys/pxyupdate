sudo chmod +x /usr/local/bin/*
echo '                                 '
echo "       *****UPDATE COMPLETED*****"
echo '                                 '
rm ~pxy/sys/exe/run/filePnL.csv
mv ~pxy/sys/exe/run/_filePnL.csv ~pxy/sys/exe/run/filePnL.csv 
