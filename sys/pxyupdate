#!/bin/bash
echo "Changing directory to $HOME/pxy"
cd $HOME/pxy
echo "Fetching all updates from the remote Git repository"
git fetch --all
echo "Resetting the local branch 'main' to match the remote branch 'origin/main'"
git reset --hard origin/main
echo "Copying files from ~/pxy/sys/ to /usr/local/bin/"
sudo cp ~/pxy/sys/* /usr/local/bin/
echo "Granting execute permissions to files in /usr/local/bin/"
sudo chmod +x /usr/local/bin/*
