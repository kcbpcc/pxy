#!/bin/bash
echo "CD DIR to $HOME/pxy"
cd $HOME/pxy
echo "GET UPDATES"
git fetch --all
echo "RESET"
git reset --hard origin/main
echo "COPY ~/pxy/sys/ to /usr/local/bin/"
sudo cp ~/pxy/sys/* /usr/local/bin/ &> /dev/null
echo "GRANT /usr/local/bin/"
sudo chmod +x /usr/local/bin/*
echo "       *****UPDATE COMPLETED*****"
