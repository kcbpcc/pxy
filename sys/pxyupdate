#!/bin/bash
cd $HOME/pxy
mv ~pxy/sys/exe/run/filePnL.csv ~pxy/sys/exe/run/_filePnL.csv 
echo '                                 '
echo "       *****GET UPDATES**********"
echo '                                 '
git fetch --all
echo '                                 '
echo "       *****RESET SOFTWERE*******"
