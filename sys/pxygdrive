#!/bin/bash

# Add the PPA
sudo add-apt-repository ppa:alessandro-strada/ppa

# Update package list
sudo apt-get update

# Install google-drive-ocamlfuse
sudo apt-get install google-drive-ocamlfuse

# Configure and authorize google-drive-ocamlfuse
google-drive-ocamlfuse

# Create a directory to mount Google Drive
mkdir -p ~/google-drive

# Mount Google Drive
google-drive-ocamlfuse ~/google-drive

echo "Google Drive is mounted at ~/google-drive"

# Optional: Add an entry to /etc/fstab for automatic mounting on boot
echo "google-drive-ocamlfuse#$(realpath ~/gdrive) $(realpath ~/gdrive) fuse user,auto 0 0" | sudo tee -a /etc/fstab

echo "Setup complete. You can access your Google Drive at ~/gdrive."
