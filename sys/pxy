#!/bin/bash
# ANSI color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color
source ~/env/bin/activate
while true; do
    # Display menu
    echo -e " ${YELLOW}🏛🏛PXY® PreciseXceleratedYield Pvt Ltd™🏛🏛${NC}"
    echo "******************************************"
    echo "   -pxy                   🔥        en"
    echo "   -pxypy                 🐍        py"
    echo "   -pxytail               📜        ta"
    echo "   -pxyclean              🚿        cl"
    echo "   -pxyflush              💨        fl"    
    echo "   -pxycheck              🧪        ck"
    echo "   -pxysetup              📀        st"
    echo "   -pxyupdate             📥        up"
    echo "   -pxysell-MIS           🔴        sl"    
    echo "   -pxykill-MIS           ❌        kl"
    echo "******************************************"
    echo -e " ${YELLOW}🏛🏛PXY® PreciseXceleratedYield Pvt Ltd™🏛🏛${NC}"

    # Get user input
    read -p "Enter your choice:⚙️⚙️⚙️👉👉 " choice

    # Perform actions based on user input
    case $choice in
        ta)
            echo "    📜📜📜......main.log......📜📜📜"
            pxytail
            ;;    
        fl)
            echo "...............flush put💨💨💨"
            pxyflush
            ;;    
        sl)
            echo "    🔴🔴🔴.....MIS Selling.....🔴🔴🔴"
            pxysell-MIS
            ;;   
        st)
            echo "    🐍🐍🐍 Setup.... 🐍🐍🐍"
            pxysetup
            ;;   
        kl)
            echo "    ❌❌❌.....MIS Selling.....❌❌❌"
            killpxy-MIS.py
            ;;
        up)
            echo "     🧰⚙️🔧🛠️🔐 Update PXY®...🧰⚙️🔧🛠️🔐"
            pxyupdate
            ;;
        cl)
            echo "    🚿🚿🚿 Cleanup...🚿🚿🚿"
            pxyclean
            ;;
        ck)
            echo "    🧪🧪🧪 Test All PXY®...🧪🧪🧪"
            pxycheck
            ;;
        py)
            echo "    ...................👉exe/run"
            pxypy
            ;;

        "")
            echo "........Lets have fun with PXY®  🔥💫🚀🔥"
            pxypxy
            ;;
        en)
            echo "........Lets have fun with PXY®  🔥💫🚀🔥"
            pxypxy
            ;;
        *)
            # Handle other cases if needed
            echo "Invalid choice: $choice"
            ;;
    esac
done

