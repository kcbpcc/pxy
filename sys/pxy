#!/bin/bash
# ANSI color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color
#sudo timedatectl set-timezone UTC && sudo timedatectl set-local-rtc 0 && timedatectl

# Display menu
echo -e " ${YELLOW}🏛🏛PXY® PreciseXceleratedYield Pvt Ltd™🏛🏛${NC}"
echo "******************************************"
echo "   -pxybuy                     🟢    nb"
echo "   -pxysell                    🔴    ka"
echo "   -pxybuykill                 🟢🚦  kb"
echo "   -pxysellkill                🛑🚦  ks"
echo "   -pxykill                    ❌     ka
